# GFRC Production Environment Template
# IMPORTANT: Update all values before deployment
# DO NOT commit this file to version control
# Store in secure secret management system

# ============================================
# APPLICATION SETTINGS (UPDATE BEFORE PRODUCTION)
# ============================================

APP_NAME="GFRC System"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://yourdomain.com

# Generate with: php artisan key:generate
APP_KEY=base64:GENERATE_NEW_KEY_WITH_ARTISAN

# ============================================
# SECURITY SETTINGS
# ============================================

# Password hashing strength (12-14 for production)
BCRYPT_ROUNDS=14

# Session security
SESSION_DRIVER=database
SESSION_ENCRYPT=true
SESSION_SECURE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=strict
SESSION_LIFETIME=480

# HTTPS enforcement
FORCE_HTTPS=true
HSTS_ENABLED=true
HSTS_MAX_AGE=31536000
HSTS_INCLUDE_SUBDOMAINS=true

# ============================================
# DATABASE SETTINGS (PostgreSQL Recommended)
# ============================================

DB_CONNECTION=pgsql
DB_HOST=db.yourdomain.com
DB_PORT=5432
DB_DATABASE=gfrc_production
DB_USERNAME=gfrc_prod
DB_PASSWORD=GENERATE_STRONG_PASSWORD_32_CHARS

# SSL for database connection
DB_SSL=true
DB_SSL_VERIFY=true

# ============================================
# REDIS CACHE & SESSION
# ============================================

CACHE_STORE=redis
CACHE_REDIS_SERIALIZER=igbinary
CACHE_REDIS_COMPRESSION=lz4

REDIS_HOST=redis.yourdomain.com
REDIS_PASSWORD=GENERATE_STRONG_PASSWORD_32_CHARS
REDIS_PORT=6380
REDIS_TLS=true

# ============================================
# LOGGING & MONITORING
# ============================================

LOG_CHANNEL=stack
LOG_LEVEL=warning

# Only log warnings and above to reduce log volume
# Archive logs daily
LOG_DAILY=true
LOG_MAX_FILES=30

# ============================================
# MAIL (if needed)
# ============================================

MAIL_MAILER=smtp
MAIL_HOST=smtp.yourdomain.com
MAIL_PORT=587
MAIL_USERNAME=noreply@yourdomain.com
MAIL_PASSWORD=EMAIL_PASSWORD
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@yourdomain.com
MAIL_FROM_NAME="${APP_NAME}"

# ============================================
# BACKUP SETTINGS
# ============================================

BACKUP_DRIVER=local
BACKUP_DISK=backups

# Encryption settings
BACKUP_ENCRYPTION=true
BACKUP_ENCRYPTION_KEY=GENERATE_STRONG_KEY_32_CHARS
BACKUP_ENCRYPTION_ALGORITHM=aes-256-cbc

# Compression
BACKUP_COMPRESSION=true
BACKUP_COMPRESSION_ALGORITHM=gzip

# Retention policy
BACKUP_RETENTION_DAYS=90
BACKUP_RETENTION_COUNT=30

# Backup schedule
BACKUP_SCHEDULE_TIME=02:00
BACKUP_SCHEDULE_TIMEZONE=UTC

# Cloud backup (optional)
BACKUP_CLOUD_ENABLED=true
BACKUP_CLOUD_DRIVER=s3
BACKUP_S3_BUCKET=gfrc-backups-production
BACKUP_S3_REGION=us-east-1
BACKUP_S3_KEY=AWS_ACCESS_KEY_ID
BACKUP_S3_SECRET=AWS_SECRET_ACCESS_KEY

# ============================================
# RATE LIMITING & SECURITY
# ============================================

RATE_LIMIT_LOGIN_ATTEMPTS=5
RATE_LIMIT_LOGIN_WINDOW=900  # 15 minutes

# IP-based rate limiting
RATE_LIMIT_API_REQUESTS=1000
RATE_LIMIT_API_WINDOW=3600  # 1 hour

# ============================================
# AUDIT & COMPLIANCE
# ============================================

ENABLE_AUDIT_LOG=true
AUDIT_LOG_RETENTION_DAYS=365

# Log financial transactions with full details
AUDIT_FINANCIAL_TRANSACTIONS=true

# ============================================
# API SETTINGS
# ============================================

API_PREFIX=api/v1
API_VERSION=1.0

# API rate limiting
API_RATE_LIMIT_ENABLED=true

# ============================================
# GEOLOCATION & LANGUAGE
# ============================================

APP_LOCALE=ar
APP_FALLBACK_LOCALE=en
TIMEZONE=Asia/Baghdad

# ============================================
# FILESYSTEM
# ============================================

FILESYSTEM_DISK=local
FILESYSTEM_VISIBILITY=private

# ============================================
# QUEUE
# ============================================

QUEUE_CONNECTION=database
QUEUE_FAILED_TABLE=failed_jobs

# ============================================
# ADDITIONAL PRODUCTION SETTINGS
# ============================================

# Trusted proxies (if behind load balancer)
TRUSTED_PROXIES=*
TRUSTED_PROXY_HEADERS=ACCEPT_FORWARDED_FOR,X_FORWARDED_FOR,X_FORWARDED_PROTO

# Asset URL
ASSET_URL=${APP_URL}

# Maintenance mode
MAINTENANCE_DRIVER=file

# ============================================
# OPTIONAL: AWS / EXTERNAL SERVICES
# ============================================

# AWS (if using S3 for backups or uploads)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

# ============================================
# MONITORING & ERROR TRACKING (Optional)
# ============================================

# Sentry (for error tracking)
SENTRY_ENABLED=false
SENTRY_DSN=

# New Relic (for APM)
NEW_RELIC_ENABLED=false
NEW_RELIC_APP_NAME=
NEW_RELIC_LICENSE_KEY=

# ============================================
# IMPORTANT NOTES
# ============================================
#
# 1. SECRETS MANAGEMENT:
#    - Store passwords/keys in AWS Secrets Manager, HashiCorp Vault, or similar
#    - Do NOT check this file into git
#    - Use CI/CD pipeline to inject secrets at deployment time
#
# 2. PASSWORD GENERATION:
#    Generate secure passwords with:
#    openssl rand -base64 32
#
# 3. DATABASE:
#    - Always use strong passwords (32+ characters)
#    - Use PostgreSQL in production (not SQLite)
#    - Enable SSL/TLS for database connections
#    - Use dedicated database user with minimal privileges
#
# 4. BACKUP ENCRYPTION:
#    - Generate unique encryption key for each environment
#    - Store key separately from backups
#    - Rotate encryption key quarterly
#    - Test backup restoration monthly
#
# 5. SESSION SECURITY:
#    - SESSION_ENCRYPT=true encrypts session data
#    - SESSION_SECURE=true forces HTTPS only
#    - SESSION_HTTP_ONLY=true prevents JavaScript access
#    - SESSION_SAME_SITE=strict prevents CSRF
#
# 6. RATE LIMITING:
#    - Adjust based on expected load
#    - Monitor for legitimate users hitting limits
#    - Log rate limit violations
#
# 7. SSL CERTIFICATE:
#    - Use Let's Encrypt with auto-renewal
#    - Certificate must be valid and not expired
#    - Update after domain changes
#
# 8. LOGGING:
#    - Keep LOG_LEVEL at 'warning' to avoid excessive logs
#    - Archive logs for 30+ days
#    - Monitor for ERROR and CRITICAL messages
#    - Send alerts for critical errors
#
# ============================================
